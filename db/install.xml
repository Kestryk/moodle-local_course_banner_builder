<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/course_banner_builder/db" VERSION="20260417" COMMENT="XMLDB file for Moodle local/course_banner_builder"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_course_banner_elements" COMMENT="Course banner image elements">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Course category id"/>
        <FIELD NAME="customfieldid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Reserved for later custom field support"/>
        <FIELD NAME="customfieldvalue" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Raw custom field value for custom field sources"/>
        <FIELD NAME="sourcetype" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="category"/>
        <FIELD NAME="sourcekey" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="elementtype" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false" DEFAULT="background_image"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="fitmodeoverride" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="positionanchor" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="center"/>
        <FIELD NAME="offsettoppercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="offsetrightpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="offsetbottompercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="offsetleftpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="customwidthpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="100"/>
        <FIELD NAME="customheightpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="100"/>
        <FIELD NAME="customsizekeepaspect" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="dynamicimagesizeenabled" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="imageopacity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="imagecropenabled" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="imagecropleftpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="imagecroptoppercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="imagecropwidthpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="100"/>
        <FIELD NAME="imagecropheightpercent" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="100"/>
        <FIELD NAME="borderenabled" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="bordercolor" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" DEFAULT="#FFFFFF"/>
        <FIELD NAME="borderwidth" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="borderopacity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="borderfade" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="borderstyle" TYPE="char" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="solid"/>
        <FIELD NAME="borderdashlength" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="24"/>
        <FIELD NAME="bordersides" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" DEFAULT="top,right,bottom,left"/>
        <FIELD NAME="borderinnerrounded" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="overlayenabled" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="overlaytarget" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="both"/>
        <FIELD NAME="overlaybannercolor" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" DEFAULT="#000000"/>
        <FIELD NAME="overlaybanneropacity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="25"/>
        <FIELD NAME="overlayslideshowcolor" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" DEFAULT="#000000"/>
        <FIELD NAME="overlayslideshowopacity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" SEQUENCE="false" DEFAULT="38"/>
        <FIELD NAME="overlaytitleabove" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="overlayborderabove" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="fileitemid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0" COMMENT="File API item id"/>
        <FIELD NAME="isenabled" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="categoryid" UNIQUE="false" FIELDS="categoryid"/>
        <INDEX NAME="category-sort" UNIQUE="false" FIELDS="categoryid, sortorder"/>
        <INDEX NAME="sourcekey-sort" UNIQUE="false" FIELDS="sourcekey, sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_course_banner_order" COMMENT="Reserved order configuration for banner elements">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="elementids" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="coursecustomfieldid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="customfieldvalue" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sourcetype" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="category"/>
        <FIELD NAME="sourcekey" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="compositionmode" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="random"/>
        <FIELD NAME="fitmode" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="original"/>
        <FIELD NAME="fitapplyscope" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="descendants"/>
        <FIELD NAME="customfieldpriority" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="category"/>
        <FIELD NAME="sourceparentkey" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sourceisroot" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="sourceinheritchildren" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="categoryid" UNIQUE="true" FIELDS="categoryid"/>
        <INDEX NAME="sourcekey" UNIQUE="true" FIELDS="sourcekey"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
