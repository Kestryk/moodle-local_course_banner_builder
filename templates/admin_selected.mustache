{{!
    This file is part of Moodle - http://moodle.org/

    @template local_course_banner_builder/admin_selected

    Selected banner source summary.
}}
{{#hasselection}}
    <div id="local-course-banner-builder-selected-source-content" data-selected-source-content="1">
    <div class="local-course-banner-builder-summary">
        <p class="local-course-banner-builder-summary-title"><strong>{{categoryname}}</strong></p>
        {{#hasconfiguration}}
            {{#hassummaryfields}}
                <dl class="local-course-banner-builder-summary-meta">
                    {{#summaryfields}}
                        <div class="local-course-banner-builder-summary-meta-row" data-inline-setting-row="1">
                            <dt>{{label}}</dt>
                            <dd>
                                <form method="post" action="" class="local-course-banner-builder-summary-inline-form">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="updatesourcesettingfield" value="1">
                                    <input type="hidden" name="fieldname" value="{{fieldname}}">
                                    <input type="hidden" name="categoryid" value="{{categoryid}}">
                                    <input type="hidden" name="sourcekey" value="{{sourcekey}}">
                                    <div class="local-course-banner-builder-summary-inline-view">
                                        <span class="local-course-banner-builder-summary-inline-value">{{displayvalue}}</span>
                                        {{^isreadonly}}
                                        <button type="button" class="btn btn-link p-0 icon-no-margin local-course-banner-builder-summary-inline-trigger" data-action="local-course-banner-builder-inline-edit" aria-label="{{#str}}edit{{/str}}">
                                            <i class="icon fa fa-pen fa-fw" aria-hidden="true"></i>
                                        </button>
                                        {{/isreadonly}}
                                    </div>
                                    {{^isreadonly}}
                                    <div class="local-course-banner-builder-summary-inline-edit">
                                        <label class="sr-only" for="{{fieldid}}">{{label}}</label>
                                        {{#usesourcedropdown}}
                                            <input type="hidden" id="{{fieldid}}" name="fieldvalue" value="{{selectedvalue}}" data-inline-setting-select="1" data-initial-value="{{selectedvalue}}" disabled>
                                            <div class="dropdown local-course-banner-builder-source-dropdown local-course-banner-builder-summary-source-dropdown"
                                                 data-source-dropdown="summary-sourceparent"
                                                 data-input="#{{fieldid}}">
                                                <button type="button"
                                                    class="btn btn-outline-primary btn-sm dropdown-toggle local-course-banner-builder-source-dropdown-toggle"
                                                    data-toggle="dropdown"
                                                    aria-haspopup="true"
                                                    aria-expanded="false"
                                                    data-source-dropdown-label="1">
                                                    {{displayvalue}}
                                                </button>
                                                <div class="dropdown-menu local-course-banner-builder-source-dropdown-menu">
                                                    <div class="local-course-banner-builder-source-dropdown-search">
                                                        <input type="search"
                                                            class="form-control form-control-sm"
                                                            placeholder="{{#str}}searchsourcesplaceholder, local_course_banner_builder{{/str}}"
                                                            data-action="local-course-banner-builder-filter-sources"
                                                            data-target="#{{optionsid}}">
                                                    </div>
                                                    <div class="local-course-banner-builder-source-dropdown-options" id="{{optionsid}}">
                                                        {{#options}}
                                                            <button type="button"
                                                                class="dropdown-item local-course-banner-builder-source-option {{#selected}}active{{/selected}}"
                                                                data-source-option="summary-sourceparent"
                                                                data-value="{{value}}"
                                                                data-label="{{label}}"
                                                                data-search="{{label}}">
                                                                {{label}}
                                                            </button>
                                                        {{/options}}
                                                    </div>
                                                </div>
                                            </div>
                                        {{/usesourcedropdown}}
                                        {{^usesourcedropdown}}
                                            <select id="{{fieldid}}" class="custom-select custom-select-sm" name="fieldvalue" data-inline-setting-select="1" data-initial-value="{{#options}}{{#selected}}{{value}}{{/selected}}{{/options}}" disabled title="{{helptext}}">
                                                {{#options}}
                                                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                                {{/options}}
                                            </select>
                                        {{/usesourcedropdown}}
                                        <button type="submit" class="btn btn-link p-0 icon-no-margin local-course-banner-builder-summary-inline-submit" aria-label="{{#str}}savechanges{{/str}}">
                                            <i class="icon fa fa-check fa-fw" aria-hidden="true"></i>
                                        </button>
                                        <button type="button" class="btn btn-link p-0 icon-no-margin local-course-banner-builder-summary-inline-cancel" data-action="local-course-banner-builder-inline-cancel" aria-label="{{#str}}cancel{{/str}}">
                                            <i class="icon fa fa-xmark fa-fw" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                    {{/isreadonly}}
                                </form>
                            </dd>
                        </div>
                    {{/summaryfields}}
                </dl>
            {{/hassummaryfields}}
            {{#candeletecategory}}
                <p class="mb-0">
                    <form method="post" action="" class="d-inline">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        {{#sourcekey}}<input type="hidden" name="deletesourcecontent" value="{{sourcekey}}">{{/sourcekey}}
                        {{^sourcekey}}<input type="hidden" name="deletecategorycontent" value="{{categoryid}}">{{/sourcekey}}
                        <button type="submit" class="btn btn-danger btn-sm"
                            data-modal="confirmation"
                            data-modal-title="{{#str}}confirm{{/str}}"
                            data-modal-content="{{#str}}deletecategorycontentconfirm, local_course_banner_builder{{/str}}"
                            data-modal-yes-button="{{#str}}delete{{/str}}">
                            {{#str}}deletecategorycontent, local_course_banner_builder{{/str}}
                        </button>
                    </form>
                    {{#candeleteimages}}
                        <form method="post" action="" class="d-inline">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            {{#sourcekey}}<input type="hidden" name="deletesourceimages" value="{{sourcekey}}">{{/sourcekey}}
                            {{^sourcekey}}<input type="hidden" name="deletecategoryimages" value="{{categoryid}}">{{/sourcekey}}
                            <button type="submit" class="btn btn-outline-danger btn-sm ml-2"
                                data-modal="confirmation"
                                data-modal-title="{{#str}}confirm{{/str}}"
                                data-modal-content="{{#str}}deletecategoryimagesconfirm, local_course_banner_builder{{/str}}"
                                data-modal-yes-button="{{#str}}delete{{/str}}">
                                {{#str}}deletecategoryimages, local_course_banner_builder{{/str}}
                            </button>
                        </form>
                    {{/candeleteimages}}
                </p>
            {{/candeletecategory}}
        {{/hasconfiguration}}
        {{^hasconfiguration}}
            <p class="mb-0">
                {{#str}}selectedcategoryempty, local_course_banner_builder{{/str}}
                <button type="button"
                    class="btn btn-link p-0 align-baseline local-course-banner-builder-empty-settings-link"
                    data-toggle="modal"
                    data-target="#local-course-banner-builder-source-settings-modal"
                    data-bs-toggle="modal"
                    data-bs-target="#local-course-banner-builder-source-settings-modal">
                    {{#str}}selectedcategoryemptycta, local_course_banner_builder{{/str}}
                </button>
            </p>
        {{/hasconfiguration}}
    </div>
    {{#sourcevisualeditorhtml}}
        {{{sourcevisualeditorhtml}}}
    {{/sourcevisualeditorhtml}}
    <div class="local-course-banner-builder-table-heading">
        <h3 class="h6 local-course-banner-builder-table-title">
            {{#str}}sourcelayerslist, local_course_banner_builder{{/str}}
        </h3>
        <span class="local-course-banner-builder-table-heading-spacer" aria-hidden="true"></span>
    </div>
    {{#haslayertable}}
        {{#haselements}}
            <form id="local-course-banner-builder-bulk-delete" method="post" action="">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="categoryid" value="{{categoryid}}">
                <input type="hidden" name="sourcekey" value="{{sourcekey}}">
                <input type="hidden" name="deleteselectedlayers" value="1">
            </form>
            <form id="local-course-banner-builder-bulk-update" method="post" action="">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="categoryid" value="{{categoryid}}">
                <input type="hidden" name="sourcekey" value="{{sourcekey}}">
                <input type="hidden" name="updatelayersbulk" value="1">
            </form>
        {{/haselements}}
        <div class="table-responsive">
            <table class="generaltable local-course-banner-builder-layer-table">
                <colgroup>
                    <col style="width: 14%;">
                    <col style="width: 10%;">
                    <col style="width: 22%;">
                    <col style="width: 8%;">
                    <col style="width: 16%;">
                    <col style="width: 18%;">
                    <col style="width: 12%;">
                </colgroup>
                <thead>
                    <tr>
                        <th scope="col">
                            {{#haselements}}
                                <div class="local-course-banner-builder-select-actions mt-1">
                                    <button type="button" class="btn btn-secondary btn-sm"
                                        data-action="local-course-banner-builder-toggle-selection"
                                        data-select-all-label="{{#str}}selectall, local_course_banner_builder{{/str}}"
                                        data-deselect-all-label="{{#str}}deselectall, local_course_banner_builder{{/str}}">
                                        {{#str}}selectall, local_course_banner_builder{{/str}}
                                    </button>
                                </div>
                            {{/haselements}}
                        </th>
                        <th scope="col">{{#str}}sortorder, local_course_banner_builder{{/str}}</th>
                        <th scope="col">{{#str}}layername, local_course_banner_builder{{/str}}</th>
                        <th scope="col">{{#str}}enabled, local_course_banner_builder{{/str}}</th>
                        <th scope="col">{{#str}}fitoverride, local_course_banner_builder{{/str}}</th>
                        <th scope="col">{{#str}}bannerimage, local_course_banner_builder{{/str}}</th>
                        <th scope="col">{{#str}}actions, local_course_banner_builder{{/str}}</th>
                    </tr>
                </thead>
                <tbody class="local-course-banner-builder-layer-sortable" data-layer-sortable="{{#iscumulative}}1{{/iscumulative}}{{^iscumulative}}0{{/iscumulative}}">
                    {{#elements}}
                        <tr class="{{rowclass}}" data-layer-row="1" {{#iscumulative}}{{#isreorderable}}draggable="true"{{/isreorderable}}{{/iscumulative}}>
                            <td class="local-course-banner-builder-layer-select-cell">
                                {{#iscumulative}}
                                    {{#isreorderable}}
                                    <i class="icon fa fa-arrows fa-fw local-course-banner-builder-drag-corner" title="{{#str}}dragreorderlayer, local_course_banner_builder{{/str}}" aria-hidden="true"></i>
                                    {{/isreorderable}}
                                    {{#hasorderlockhelp}}
                                    <a class="btn btn-link p-0 icon-no-margin local-course-banner-builder-lock-help local-course-banner-builder-lock-help--{{#isborderlayer}}border{{/isborderlayer}}{{#isdynamiclayer}}dynamic{{/isdynamiclayer}}"
                                       role="button"
                                       data-container="body"
                                       data-toggle="popover"
                                       data-placement="right"
                                       data-content="{{orderlockpopovercontent}}"
                                       data-html="true"
                                       data-trigger="hover focus"
                                       data-template="<div class=&quot;popover local-course-banner-builder-lock-popover local-course-banner-builder-lock-popover--{{#isborderlayer}}border{{/isborderlayer}}{{#isdynamiclayer}}dynamic{{/isdynamiclayer}}&quot; role=&quot;tooltip&quot;><div class=&quot;arrow&quot;></div><h3 class=&quot;popover-header&quot;></h3><div class=&quot;popover-body&quot;></div></div>"
                                       tabindex="0"
                                       aria-label="{{orderlocklabel}}">
                                        <i class="icon fa fa-lock fa-fw" title="{{orderlocklabel}}" role="img" aria-label="{{orderlocklabel}}"></i>
                                    </a>
                                    {{/hasorderlockhelp}}
                                {{/iscumulative}}
                                <input class="local-course-banner-builder-layer-select" type="checkbox" name="selectedelements[]" value="{{id}}" form="local-course-banner-builder-bulk-delete">
                            </td>
                            <td class="local-course-banner-builder-layer-preview-cell {{#hasbordersummary}}local-course-banner-builder-layer-preview-cell--border{{/hasbordersummary}}">
                                <input class="local-course-banner-builder-sort-input" type="hidden" name="sortorder_inline[{{id}}]" value="{{sortorder}}" form="local-course-banner-builder-bulk-update">
                                <span class="local-course-banner-builder-sort-position" data-sort-display>{{sortorder}}</span>
                                {{^iscumulative}}
                                    <span class="text-muted d-block small">{{#str}}sortordercumulativeonly, local_course_banner_builder{{/str}}</span>
                                {{/iscumulative}}
                            </td>
                            <td>
                                <input class="form-control form-control-sm" type="text" name="layername_inline[{{id}}]" value="{{name}}" form="local-course-banner-builder-bulk-update">
                            </td>
                            <td class="local-course-banner-builder-layer-enabled-cell">
                                <input type="checkbox" name="isenabled_inline[{{id}}]" value="1" form="local-course-banner-builder-bulk-update" {{#enabledchecked}}checked{{/enabledchecked}}>
                            </td>
                            <td class="local-course-banner-builder-fit-override-cell {{fitoverridecellclass}}" {{#fitoverridecellstyle}}style="{{fitoverridecellstyle}}"{{/fitoverridecellstyle}}>
                                {{#showfitoverrideselect}}
                                    <select class="custom-select custom-select-sm" name="fitmodeoverride_inline[{{id}}]" form="local-course-banner-builder-bulk-update" title="{{fitoverridehelp}}">
                                        {{#fitoverrideoptions}}
                                            <option value="{{value}}" {{#selected}}selected{{/selected}} {{#disabled}}disabled{{/disabled}}>{{label}}</option>
                                        {{/fitoverrideoptions}}
                                    </select>
                                {{/showfitoverrideselect}}
                                {{^showfitoverrideselect}}
                                    <span class="text-muted">{{fitoverridedisplay}}</span>
                                {{/showfitoverrideselect}}
                                {{#hasfitoverride}}
                                    <details class="local-course-banner-builder-help-bubble local-course-banner-builder-override-help">
                                        <summary title="{{fitoverridehelp}}">?</summary>
                                        <div>{{fitoverridehelp}}</div>
                                    </details>
                                {{/hasfitoverride}}
                                {{#haslayersummary}}
                                    <div class="local-course-banner-builder-border-summary mt-2">
                                        <dl class="local-course-banner-builder-border-summary-list">
                                            {{#layersummaryitems}}
                                                <div>
                                                    <dt>{{label}}</dt>
                                                    <dd>{{value}}</dd>
                                                </div>
                                            {{/layersummaryitems}}
                                        </dl>
                                    </div>
                                {{/haslayersummary}}
                            </td>
                            <td>
                                {{#hasbordersummary}}
                                    <div class="local-course-banner-builder-border-summary">
                                        <strong class="local-course-banner-builder-border-summary-title">{{bordersummarytitle}}</strong>
                                        <dl class="local-course-banner-builder-border-summary-list">
                                            {{#bordersummaryitems}}
                                                <div>
                                                    <dt>{{label}}</dt>
                                                    <dd>{{value}}</dd>
                                                </div>
                                            {{/bordersummaryitems}}
                                        </dl>
                                    </div>
                                {{/hasbordersummary}}
                                {{^hasbordersummary}}
                                    {{#imageurl}}
                                        <div class="local-course-banner-builder-admin-preview{{#isdynamiclayer}} local-course-banner-builder-admin-preview--dynamic{{/isdynamiclayer}}"
                                            {{#isdynamiclayer}}
                                            role="button"
                                            tabindex="0"
                                            data-container="body"
                                            data-toggle="popover"
                                            data-placement="left"
                                            data-content="{{dynamicpopovercontent}}"
                                            data-html="true"
                                            data-trigger="hover focus"
                                            aria-label="{{dynamiclabel}}"
                                            title="{{dynamiclabel}}"
                                            {{/isdynamiclayer}}>
                                            <img src="{{imageurl}}" alt="">
                                        </div>
                                    {{/imageurl}}
                                    {{^imageurl}}
                                        <span class="text-muted">{{#str}}nolayeradded, local_course_banner_builder{{/str}}</span>
                                    {{/imageurl}}
                                {{/hasbordersummary}}
                            </td>
                            <td class="local-course-banner-builder-layer-actions-cell">
                                <div class="local-course-banner-builder-action-list">
                                    <button type="button"
                                        class="btn btn-secondary btn-sm"
                                        data-edit-layer-url="{{editurl}}">
                                        {{#str}}editimage, local_course_banner_builder{{/str}}
                                    </button>
                                    <a class="btn btn-danger btn-sm" href="{{deleteurl}}">{{#str}}delete{{/str}}</a>
                                </div>
                            </td>
                        </tr>
                    {{/elements}}
                </tbody>
            </table>
        </div>
        {{#haschainborderlayer}}
            <div class="table-responsive local-course-banner-builder-chain-table">
                <table class="generaltable">
                    <colgroup>
                        <col style="width: 14%;">
                        <col style="width: 10%;">
                        <col style="width: 22%;">
                        <col style="width: 8%;">
                        <col style="width: 16%;">
                        <col style="width: 18%;">
                        <col style="width: 12%;">
                    </colgroup>
                    <tbody>
                        {{#chainborderlayer}}
                            <tr class="{{rowclass}}" data-chain-border-row="1">
                                <td class="local-course-banner-builder-layer-select-cell">
                                    <strong>{{actionlabel}}</strong>
                                </td>
                                <td>
                                    <span class="local-course-banner-builder-sort-position" aria-hidden="true">&mdash;</span>
                                </td>
                                <td>
                                    <strong>{{name}}</strong>
                                </td>
                                <td>{{enabledlabel}}</td>
                                <td>
                                    <span class="text-muted">{{#str}}inherited, local_course_banner_builder{{/str}}</span>
                                </td>
                                <td></td>
                                <td>
                                    <a class="btn btn-secondary btn-sm" href="{{sourceediturl}}">
                                        {{#str}}editsourceoflayer, local_course_banner_builder{{/str}}
                                    </a>
                                </td>
                            </tr>
                        {{/chainborderlayer}}
                    </tbody>
                </table>
            </div>
        {{/haschainborderlayer}}
        {{^haselements}}
            <p class="local-course-banner-builder-empty-layer-list text-muted mb-0">
                {{#str}}nosourcelayers, local_course_banner_builder{{/str}}
            </p>
        {{/haselements}}
        {{#haselements}}
            <form id="local-course-banner-builder-delete-all-layers" method="post" action="">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="categoryid" value="{{categoryid}}">
                <input type="hidden" name="sourcekey" value="{{sourcekey}}">
                <input type="hidden" name="deletealllayersajax" value="1">
            </form>
            <div class="local-course-banner-builder-bulk-action-row mt-3">
                <button type="button" class="btn btn-danger local-course-banner-builder-bulk-delete-button"
                    data-action="local-course-banner-builder-delete-all-layers"
                    data-confirm-title="{{#str}}confirm{{/str}}"
                    data-confirm-message="{{#str}}deletealllayersconfirm, local_course_banner_builder{{/str}}">
                    <i class="fa fa-trash-can me-2" aria-hidden="true"></i>
                    {{#str}}deletealllayers, local_course_banner_builder{{/str}}
                </button>
                <button type="submit" class="btn btn-danger local-course-banner-builder-bulk-delete-button" form="local-course-banner-builder-bulk-delete"
                    data-modal="confirmation"
                    data-modal-title="{{#str}}confirm{{/str}}"
                    data-modal-content="{{#str}}deleteselectedlayersconfirm, local_course_banner_builder{{/str}}"
                    data-modal-yes-button="{{#str}}delete{{/str}}">
                    <i class="fa fa-trash-can me-2" aria-hidden="true"></i>
                    {{#str}}deleteselectedlayers, local_course_banner_builder{{/str}}
                </button>
                <button type="submit" class="btn btn-primary local-course-banner-builder-bulk-save-button" form="local-course-banner-builder-bulk-update">
                    <i class="fa fa-save me-2" aria-hidden="true"></i>
                    {{#str}}savelayerchanges, local_course_banner_builder{{/str}}
                </button>
            </div>
        {{/haselements}}
    {{/haslayertable}}
    {{^haslayertable}}
        {{#hasconfiguration}}
            <p>{{#str}}nobannerconfigured, local_course_banner_builder{{/str}}</p>
        {{/hasconfiguration}}
    {{/haslayertable}}
    </div>
{{/hasselection}}
